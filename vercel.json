{
  "version": 2,
  "buildCommand": "cd client_side && npm install && npm run build",
  "outputDirectory": "client_side/build",
  "installCommand": "cd server && npm install",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "server/**"
    }
  }
}