# Grok API Key (from https://console.x.ai/)
GROK_API_KEY=your_grok_api_key_here

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/ai_quiz

# Trust reverse proxy headers in production (Vercel/Render/Railway)
# true | false
TRUST_PROXY=true

# Optional Mongo tuning for serverless cold starts and flaky networks
MONGODB_SERVER_SELECTION_TIMEOUT_MS=15000
MONGODB_SOCKET_TIMEOUT_MS=45000
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=1

# Rate limit tuning (defaults: API=2000 in dev / 600 in prod, AUTH=20)
API_RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_MAX=20
AI_RATE_LIMIT_MAX=80

# Max request processing time before returning 503 timeout
REQUEST_TIMEOUT_MS=290000

# Server port
PORT=5000
